generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROFESOR
  PADRE
}

enum CategoryType {
  INFANTIL
  JUVENIL
  PROFESIONAL
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum PlayerStatus {
  ACTIVE
  INJURED
  INACTIVE
  SUSPENDED
}

enum ScholarshipType {
  FULL
  PARTIAL_50
  PARTIAL_25
  NONE
}

enum PaymentPlan {
  MONTHLY
  ANNUAL
  SCHOLARSHIP
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  IN_PLAN
}

enum DocumentType {
  BIRTH_CERT
  DNI
  DNI_FRONT
  DNI_BACK
  PARENT_DOC
  MEDICAL
  REPORT_CARD
  OTHER
}

enum EducationStatus {
  PRIMARIA
  SECUNDARIA
  TERCIARIO
  UNIVERSITARIO
  FINALIZADO
  OTRO
}

enum SchoolShift {
  MANANA
  TARDE
  NOCHE
  DOBLE
}

enum TransferStatus {
  SIN_PASE
  EN_TRAMITE
  CONFIRMADO
}

enum EventType {
  TRAINING
  MATCH
  MEETING
  NOTICE
  OTHER
}

enum EventAudience {
  ALL
  ADMIN
  PROFESOR
  PADRE
  CATEGORY
}

enum InstallmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Club {
  id          String       @id @default(cuid())
  name        String
  logo        String?
  createdAt   DateTime     @default(now())
  players     Player[]
  categories  Category[]
  users       User[]
  invitations Invitation[]
}

model User {
  id                 String     @id @default(cuid())
  clerkId            String?    @unique
  email              String     @unique
  name               String
  role               Role
  title              String?    // ej "DT", "Coordinador", "Preparador físico" — cosmético
  clubId             String
  club               Club       @relation(fields: [clubId], references: [id])
  children           Player[]   @relation("ParentChildren")
  assignedCategories Category[] @relation("AssignedCategories")
  createdAt          DateTime   @default(now())

  @@index([clubId])
  @@index([role])
}

model Category {
  id                String   @id @default(cuid())
  name              String
  type              CategoryType
  year              Int
  clubId            String
  club              Club     @relation(fields: [clubId], references: [id])
  // Categoría principal de los jugadores (1:N). Es la que usa cobranza y la
  // que se muestra como "su categoría" en la mayoría de las pantallas.
  players           Player[]
  // Jugadores que ALSO están en esta categoría (no es la principal pero
  // entrenan/juegan acá también). Sin cuota duplicada.
  additionalPlayers Player[] @relation("AdditionalCategories")
  assignedTo        User[]   @relation("AssignedCategories")

  @@index([clubId])
}

model Player {
  id                    String           @id @default(cuid())
  firstName             String
  lastName              String
  dni                   String?          @unique
  // Número de registro AFA / COMET (las planillas oficiales lo usan como ID único)
  afaId                 String?          @unique
  birthDate             DateTime
  photo                 String?
  nationality           String           @default("Argentina")
  citizenship           String?
  observations          String?

  // Domicilio
  address               String?
  locality              String?
  province              String?

  // Contacto personal
  personalPhone         String?
  personalEmail         String?
  notificationEmail     String?

  // Contacto de emergencia
  emergencyContactName  String?
  emergencyContactRelation String?
  emergencyContactPhone String?
  emergencyContactEmail String?
  // (legacy combinado, se mantiene por retro-compatibilidad)
  emergencyContact      String?

  // Escolaridad
  schoolName            String?
  schoolStatus          EducationStatus?
  schoolShift           SchoolShift?
  schoolStartTime       String?  // "08:00"
  schoolEndTimeTuesday  String?
  schoolEndTimeWednesday String?
  schoolEndTimeThursday String?
  schoolEndTimeFriday   String?
  // (legacy JSON, se mantiene)
  schoolSchedule        Json?

  // Obra social
  hasHealthInsurance    Boolean          @default(false)
  healthInsurance       String?
  healthInsurancePlan   String?
  healthInsuranceNumber String?

  // Estado administrativo / club
  position              PlayerPosition?
  heightCm              Int?
  status                PlayerStatus     @default(ACTIVE)
  scholarshipType       ScholarshipType? @default(NONE)
  scholarshipPercent    Int?
  paymentPlan           PaymentPlan      @default(MONTHLY)
  monthlyFee            Decimal          @default(0)
  fitnessExpiry         DateTime?
  afaRegistration       String?
  clothingPaid          Boolean          @default(false)
  transferStatus        TransferStatus?
  registeredIn2025      Boolean          @default(false)
  lastInstallmentNote   String?

  // Grupo familiar: jugadores con el mismo familyGroupId son hermanos.
  // El sistema aplica descuento progresivo a hermanos (ver lib/family.ts).
  familyGroupId         String?
  familyDiscountPercent Int?             // override manual del descuento; null = usa default

  // Categorización
  // categoryId / category = PRINCIPAL del jugador (usada para cobranza).
  // Si la categoría es PROFESIONAL, no se le generan cuotas.
  categoryId            String
  category              Category         @relation(fields: [categoryId], references: [id])
  // Categorías adicionales en las que también juega (no genera doble cuota)
  additionalCategories  Category[]       @relation("AdditionalCategories")

  // Relaciones
  parents               User[]           @relation("ParentChildren")
  payments              Payment[]
  attendances           Attendance[]
  documents             Document[]
  notes                 PlayerNote[]
  installmentPlans      InstallmentPlan[]
  clubId                String
  club                  Club             @relation(fields: [clubId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([clubId])
  @@index([categoryId])
  @@index([status])
  @@index([afaId])
}

model Payment {
  id            String        @id @default(cuid())
  playerId      String
  player        Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  amount        Decimal
  month         Int
  year          Int
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([playerId])
  @@index([status])
  @@index([year, month])
}

model Attendance {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date      DateTime
  present   Boolean
  notes     String?
  createdAt DateTime @default(now())

  @@unique([playerId, date])
  @@index([date])
}

model Document {
  id         String       @id @default(cuid())
  playerId   String
  player     Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type       DocumentType
  name       String
  url        String
  uploadedAt DateTime     @default(now())
  uploadedBy String

  @@index([playerId])
}

model Notice {
  id          String       @id @default(cuid())
  title       String
  body        String
  createdAt   DateTime     @default(now())
  // Si es encuesta, `pollOptions` tiene las opciones de respuesta.
  // Vacío = aviso normal sin votación.
  pollOptions String[]     @default([])
  pollClosesAt DateTime?
  votes       NoticeVote[]
}

model NoticeVote {
  id        String   @id @default(cuid())
  noticeId  String
  notice    Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  userId    String   // quién votó (User.id)
  optionIdx Int      // índice en pollOptions
  createdAt DateTime @default(now())

  @@unique([noticeId, userId]) // un voto por user por aviso
  @@index([noticeId])
}

enum StaffTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum StaffTaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Tareas pendientes del staff. Las puede crear el admin manualmente o se
/// auto-generan por triggers (ej. apto vencido → tarea para coordinador).
model StaffTask {
  id              String            @id @default(cuid())
  title           String
  description     String?
  status          StaffTaskStatus   @default(PENDING)
  priority        StaffTaskPriority @default(NORMAL)
  assignedToId    String?           // User.id del responsable; null = sin asignar
  assignedToRole  Role?             // Si está dirigida a un rol entero (ej. todos los profes)
  createdById     String            // User.id de quién la creó (o "system" para auto)
  // Referencias opcionales a entidades relacionadas
  relatedPlayerId String?
  relatedPaymentId String?
  dueDate         DateTime?
  completedAt     DateTime?
  completedById   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([assignedToId, status])
  @@index([assignedToRole, status])
  @@index([status])
}

model PlayerNote {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  pinned    Boolean  @default(false)
  category  String?  // ej: "medico", "academico", "disciplinario", "familiar"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId])
  @@index([authorId])
}

model InstallmentPlan {
  id           String                @id @default(cuid())
  playerId     String
  player       Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)
  totalAmount  Decimal
  installments Int
  notes        String?
  status       InstallmentPlanStatus @default(ACTIVE)
  createdById  String
  createdAt    DateTime              @default(now())
  paymentIds   String[]              @default([])

  @@index([playerId])
  @@index([status])
}

model Event {
  id            String         @id @default(cuid())
  title         String
  description   String?
  date          DateTime
  endDate       DateTime?
  location      String?
  type          EventType      @default(OTHER)
  audience      EventAudience  @default(ALL)
  categoryId    String?
  // Si pertenece a una serie recurrente, comparte seriesId con sus hermanos.
  // Permite borrar/editar toda la serie en bulk.
  seriesId      String?
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([audience])
  @@index([seriesId])
}

model Invitation {
  id           String    @id @default(cuid())
  token        String    @unique
  email        String?
  role         Role
  title        String?
  clubId       String
  club         Club      @relation(fields: [clubId], references: [id])
  categoryIds  String[]  @default([])
  childrenIds  String[]  @default([])
  createdById  String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  usedAt       DateTime?
  usedByUserId String?
  revoked      Boolean   @default(false)

  @@index([token])
  @@index([clubId])
  @@index([usedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  changes    Json
  userId     String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
