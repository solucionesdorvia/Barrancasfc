generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROFESOR
  PADRE
}

enum CategoryType {
  INFANTIL
  JUVENIL
  PROFESIONAL
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum PlayerStatus {
  ACTIVE
  INJURED
  INACTIVE
  SUSPENDED
}

enum ScholarshipType {
  FULL
  PARTIAL_50
  PARTIAL_25
  NONE
}

enum PaymentPlan {
  MONTHLY
  ANNUAL
  SCHOLARSHIP
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  IN_PLAN
}

enum DocumentType {
  BIRTH_CERT
  DNI
  MEDICAL
  REPORT_CARD
  OTHER
}

enum EventType {
  TRAINING
  MATCH
  MEETING
  NOTICE
  OTHER
}

enum EventAudience {
  ALL
  ADMIN
  PROFESOR
  PADRE
  CATEGORY
}

enum InstallmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Club {
  id          String       @id @default(cuid())
  name        String
  logo        String?
  createdAt   DateTime     @default(now())
  players     Player[]
  categories  Category[]
  users       User[]
  invitations Invitation[]
}

model User {
  id                 String     @id @default(cuid())
  clerkId            String?    @unique
  email              String     @unique
  name               String
  role               Role
  title              String?    // ej "DT", "Coordinador", "Preparador físico" — cosmético
  clubId             String
  club               Club       @relation(fields: [clubId], references: [id])
  children           Player[]   @relation("ParentChildren")
  assignedCategories Category[] @relation("AssignedCategories")
  createdAt          DateTime   @default(now())

  @@index([clubId])
  @@index([role])
}

model Category {
  id         String       @id @default(cuid())
  name       String
  type       CategoryType
  year       Int
  clubId     String
  club       Club         @relation(fields: [clubId], references: [id])
  players    Player[]
  assignedTo User[]       @relation("AssignedCategories")

  @@index([clubId])
}

model Player {
  id                    String           @id @default(cuid())
  firstName             String
  lastName              String
  dni                   String           @unique
  birthDate             DateTime
  photo                 String?
  nationality           String           @default("Argentina")
  address               String?
  emergencyContact      String?
  schoolName            String?
  schoolSchedule        Json?
  position              PlayerPosition?
  heightCm              Int?
  status                PlayerStatus     @default(ACTIVE)
  scholarshipType       ScholarshipType? @default(NONE)
  scholarshipPercent    Int?
  paymentPlan           PaymentPlan      @default(MONTHLY)
  monthlyFee            Decimal          @default(0)
  healthInsurance       String?
  healthInsuranceNumber String?
  fitnessExpiry         DateTime?
  afaRegistration       String?
  categoryId            String
  category              Category         @relation(fields: [categoryId], references: [id])
  parents               User[]           @relation("ParentChildren")
  payments              Payment[]
  attendances           Attendance[]
  documents             Document[]
  notes                 PlayerNote[]
  installmentPlans      InstallmentPlan[]
  clubId                String
  club                  Club             @relation(fields: [clubId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([clubId])
  @@index([categoryId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  playerId      String
  player        Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  amount        Decimal
  month         Int
  year          Int
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?
  receiptUrl    String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([playerId])
  @@index([status])
  @@index([year, month])
}

model Attendance {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  date      DateTime
  present   Boolean
  notes     String?
  createdAt DateTime @default(now())

  @@unique([playerId, date])
  @@index([date])
}

model Document {
  id         String       @id @default(cuid())
  playerId   String
  player     Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type       DocumentType
  name       String
  url        String
  uploadedAt DateTime     @default(now())
  uploadedBy String

  @@index([playerId])
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
}

model PlayerNote {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  pinned    Boolean  @default(false)
  category  String?  // ej: "medico", "academico", "disciplinario", "familiar"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId])
  @@index([authorId])
}

model InstallmentPlan {
  id           String                @id @default(cuid())
  playerId     String
  player       Player                @relation(fields: [playerId], references: [id], onDelete: Cascade)
  totalAmount  Decimal
  installments Int
  notes        String?
  status       InstallmentPlanStatus @default(ACTIVE)
  createdById  String
  createdAt    DateTime              @default(now())
  paymentIds   String[]              @default([])

  @@index([playerId])
  @@index([status])
}

model Event {
  id            String         @id @default(cuid())
  title         String
  description   String?
  date          DateTime
  endDate       DateTime?
  location      String?
  type          EventType      @default(OTHER)
  audience      EventAudience  @default(ALL)
  categoryId    String?
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([audience])
}

model Invitation {
  id           String    @id @default(cuid())
  token        String    @unique
  email        String?
  role         Role
  title        String?
  clubId       String
  club         Club      @relation(fields: [clubId], references: [id])
  categoryIds  String[]  @default([])
  childrenIds  String[]  @default([])
  createdById  String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  usedAt       DateTime?
  usedByUserId String?
  revoked      Boolean   @default(false)

  @@index([token])
  @@index([clubId])
  @@index([usedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  changes    Json
  userId     String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
